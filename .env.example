# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# DeepSeek API Key（必须，用于 LLM 调用）
DEEPSEEK_API_KEY=sk-xxx

# DeepSeek API Base（可选，默认 https://api.deepseek.com/v1）
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# OpenAI API Key（可选，仅 RAG 示例需要，用于 Embeddings）
# 如果没有，RAG 示例会跳过 Embeddings 步骤
OPENAI_API_KEY=sk-xxx

# MCP Server URL（可选，仅 MCP 示例需要）
# MCP_SERVER_URL=https://mcp.api-inference.modelscope.net/1e0bf1aca47848/mcp
